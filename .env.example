# ──────────────────────────────────────────────────────────
# CAIS — plantilla de variables de entorno
# Copia este archivo a .env y rellena los valores.
#   cp .env.example .env
# ──────────────────────────────────────────────────────────

# ─── Requeridas ───────────────────────────────────────────

# Conexión a MySQL (Prisma).
# Dev nativo:  mysql://user:user@localhost:3307/cais
# Prod docker: mysql://user:<strong>@db:3306/cais
DATABASE_URL=mysql://user:user@localhost:3307/cais

# URL pública del frontend (CORS + redirects en correos).
FRONTEND_URL=http://localhost:5173

# Secret de express-session. Mínimo 32 chars aleatorios.
# Genera con: openssl rand -hex 32
SESSION_SECRET=dev-secret-cambia-esto-en-prod-min-32-chars

# ─── Opcionales ───────────────────────────────────────────

# SMTP (Gmail con app password). Sin esto, los correos
# transaccionales (invitaciones, reset de password) fallan.
EMAIL_USER=
EMAIL_PASS=

# Puerto del backend (default 8000).
# PORT=8000

# Orígenes adicionales para CORS, separados por coma.
# CORS_ORIGINS=https://staging.cais.uabc.mx,https://cais.uabc.mx

# Límite del body JSON (default 100kb).
# JSON_BODY_LIMIT=200kb

# ─── Solo producción (docker-compose.yml) ─────────────────
# Estas vars las consume el docker-compose.yml al desplegar.
# En dev nativo no se usan.

# MYSQL_ROOT_PASSWORD=
# MYSQL_DATABASE=cais
# MYSQL_USER=user
# MYSQL_PASSWORD=
# VITE_API_URL=https://api.cais.uabc.mx
# IMAGE_TAG=v1.0.0
# FRONTEND_PORT=8080
# BACKEND_PORT=8000
