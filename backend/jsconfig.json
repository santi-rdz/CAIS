{
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@cais/shared/*": ["../shared/*"],
      "#app": ["./src/app.js"],
      "#config/*": ["./src/config/*"],
      "#lib/*": ["./src/lib/*"],
      "#models/*": ["./src/models/*"],
      "#controllers/*": ["./src/controllers/*"],
      "#middleware/*": ["./src/middleware/*"],
      "#routes/*": ["./src/routes/*"],
      "#services/*": ["./src/services/*"]
    }
  },
  "include": ["src"]
}
