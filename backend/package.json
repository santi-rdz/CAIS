{
  "name": "backend",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --forceExit",
    "test:debug": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --forceExit --detectOpenHandles",
    "file": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --forceExit --testPathPatterns",
    "start": "node --watch src/app.js",
    "prisma:pull": "prisma db pull",
    "prisma:generate": "prisma generate",
    "prisma:sync": "pnpm run prisma:pull && pnpm run prisma:generate",
    "prisma:studio": "prisma studio",
    "prisma:seed": "prisma db seed"
  },
  "dependencies": {
    "@cais/shared": "workspace:*",
    "@prisma/adapter-mariadb": "7.4.2",
    "@prisma/client": "7.4.2",
    "bcryptjs": "3.0.3",
    "cors": "2.8.5",
    "dotenv": "17.2.3",
    "express": "5.2.1",
    "express-rate-limit": "8.4.1",
    "express-session": "1.19.0",
    "helmet": "8.2.0",
    "mariadb": "3.5.2",
    "mysql2": "3.15.3",
    "nodemailer": "8.0.10",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "jest": "30.2.0",
    "prisma": "7.4.2",
    "supertest": "7.2.2"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "type": "module",
  "imports": {
    "#app": "./src/app.js",
    "#config/*": "./src/config/*",
    "#lib/*": "./src/lib/*",
    "#models/*": "./src/models/*",
    "#controllers/*": "./src/controllers/*",
    "#middleware/*": "./src/middleware/*",
    "#routes/*": "./src/routes/*",
    "#services/*": "./src/services/*"
  }
}
