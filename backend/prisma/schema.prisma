  cedula                String?                 @db.VarChar(20)
  inicio_servicio       String?                 @db.VarChar(8)
  fin_servicio          String?                 @db.VarChar(8)
  bitacora_emergencias  bitacora_emergencias[]
  historias_medicas     historias_medicas[]
  invitaciones_registro invitaciones_registro[]
  notas_evolucion       notas_evolucion[]
  pacientes             pacientes[]
  registro_auditoria    registro_auditoria[]
  areas                 areas?                  @relation(fields: [area_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_usuario_area")
  estados               estados                 @relation(fields: [estado_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_usuario_estado")
  roles                 roles                   @relation(fields: [rol_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_usuario_rol")

  @@index([area_id], map: "fk_usuario_area")
  @@index([estado_id], map: "fk_usuario_estado")
  @@index([rol_id], map: "fk_usuario_rol")
}
