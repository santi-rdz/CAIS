generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model acciones {
  id                 Int                  @id @default(autoincrement())
  codigo             String               @unique(map: "codigo") @db.VarChar(50)
  registro_auditoria registro_auditoria[]
}

model adicciones {
  id                            Int                             @id @default(autoincrement())
  adicto_tabaco                 String?                         @db.VarChar(10)
  tabaco_frecuencia             String?                         @db.VarChar(20)
  num_cigarros_d                Int?                            @db.TinyInt
  adicto_alcohol                String?                         @db.VarChar(10)
  alcohol_frecuencia            String?                         @db.VarChar(20)
  ml_ocasion                    Int?                            @db.SmallInt
  adicto_droga                  String?                         @db.VarChar(10)
  drogas_frecuencia             String?                         @db.VarChar(20)
  cual_droga                    String?                         @db.Text
  adicto_med_contr              String?                         @db.VarChar(10)
  med_contr_frecuencia          String?                         @db.VarChar(20)
  cual_med_contr                String?                         @db.Text
  historias_pacientes_nutricion historias_pacientes_nutricion[]
}

model antecedentes_familiares {
  id                 Int               @id @default(autoincrement())
  historia_medica_id Bytes             @unique(map: "historia_medica_id") @db.Binary(16)
  padre              String?           @db.VarChar(255)
  madre              String?           @db.VarChar(255)
  abuelo_paterno     String?           @db.VarChar(255)
  abuelo_materno     String?           @db.VarChar(255)
  abuela_paterna     String?           @db.VarChar(255)
  abuela_materna     String?           @db.VarChar(255)
  otros              String?           @db.VarChar(255)
  historias_medicas  historias_medicas @relation(fields: [historia_medica_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_af_historia")
}

model antecedentes_no_patologicos {
  id                            Int               @id @default(autoincrement())
  historia_medica_id            Bytes             @unique(map: "historia_medica_id") @db.Binary(16)
  alimentacion_adecuada         Boolean?
  calidad_cantidad_alimentacion String?           @db.Text
  higiene_adecuada              String?           @db.Text
  actividad_fisica              String?           @db.Text
  inmunizaciones_completas      Boolean?
  zoonosis                      Boolean?
  tipo_zoonosis                 String?           @db.Text
  historias_medicas             historias_medicas @relation(fields: [historia_medica_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_antecedentes_np_historia")
}

model antecedentes_patologicos {
  id                      Int               @id @default(autoincrement())
  historia_medica_id      Bytes             @unique(map: "historia_medica_id") @db.Binary(16)
  cronico_degenerativos   String?           @db.Text
  quirurgicos             String?           @db.Text
  hospitalizaciones       String?           @db.Text
  traumaticos             String?           @db.Text
  transfusionales         String?           @db.Text
  transplantes            String?           @db.Text
  alergicos               String?           @db.Text
  infectocontagiosos      String?           @db.Text
  toxicomanias            String?           @db.Text
  covid_19                String?           @db.Text
  psicologia_psiquiatria  String?           @db.Text
  gyo                     String?           @db.Text
  enfermedades_congenitas String?           @db.Text
  enfermedades_infancia   String?           @db.Text
  historias_medicas       historias_medicas @relation(fields: [historia_medica_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ap_historia")
}

model aparatos_sistemas {
  id                 Int                @id @default(autoincrement())
  historia_medica_id Bytes?             @unique(map: "historia_medica_id") @db.Binary(16)
  nota_evolucion_id  Bytes?             @unique(map: "nota_evolucion_id") @db.Binary(16)
  neurologico        String?            @db.Text
  cardiovascular     String?            @db.Text
  respiratorio       String?            @db.Text
  hematologico       String?            @db.Text
  digestivo          String?            @db.Text
  musculoesqueletico String?            @db.Text
  genitourinario     String?            @db.Text
  endocrinologico    String?            @db.Text
  metabolico         String?            @db.Text
  nutricional        String?            @db.Text
  historias_medicas  historias_medicas? @relation(fields: [historia_medica_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_as_historia")
  notas_evolucion    notas_evolucion?   @relation(fields: [nota_evolucion_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_as_nota")
}

model areas {
  id       Int        @id @default(autoincrement())
  nombre   String     @unique(map: "nombre") @db.VarChar(100)
  usuarios usuarios[]
}

model balance_acido_base {
  id                  Int                   @id @default(autoincrement())
  ph_serico           Float?                @db.Float
  saturacion_o2       Float?                @db.Float
  bicarbonato         Float?                @db.Float
  pco2_total          Float?                @db.Float
  eval_bioq_nutricion eval_bioq_nutricion[]
}

model bitacora_emergencias {
  id                Bytes     @id @default(dbgenerated("(uuid_to_bin(uuid()))")) @db.Binary(16)
  usuario_id        Bytes     @db.Binary(16)
  fecha_hora        DateTime? @default(now()) @db.DateTime(0)
  ubicacion         String    @db.VarChar(255)
  nombre            String?   @db.VarChar(255)
  matricula         String?   @db.VarChar(20)
  telefono          String?   @db.VarChar(30)
  diagnostico       String?   @db.VarChar(255)
  accion_realizada  String?   @db.VarChar(255)
  tratamiento_admin String?   @db.VarChar(255)
  recurrente        Boolean?  @default(false)
  usuarios          usuarios  @relation(fields: [usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_bitacora_usuario")

  @@index([usuario_id], map: "fk_bitacora_usuario")
}

model cal_get_nutr {
  id               Int       @id @default(autoincrement())
  paciente_id      Bytes     @db.Binary(16)
  fecha_eval       DateTime? @default(dbgenerated("(curdate())")) @db.Date
  verdura          Int?      @db.TinyInt
  fruta            Int?      @db.TinyInt
  cereal_sin_grasa Int?      @db.TinyInt
  cereal_con_grasa Int?      @db.TinyInt
  leguminosas      Int?      @db.TinyInt
  aoa_a            Int?      @db.TinyInt
  aoa_b            Int?      @db.TinyInt
  aoa_c            Int?      @db.TinyInt
  aoa_d            Int?      @db.TinyInt
  leche_a          Int?      @db.TinyInt
  leche_b          Int?      @db.TinyInt
  leche_c          Int?      @db.TinyInt
  grasa_a          Int?      @db.TinyInt
  grasa_b          Int?      @db.TinyInt
  azucares         Int?      @db.TinyInt
  rice_dream       Int?      @db.TinyInt
  silk             Int?      @db.TinyInt
  soyactive        Int?      @db.TinyInt
  almond_breeze    Int?      @db.TinyInt
  aube_baja        Int?      @db.TinyInt
  nan_one          Int?      @db.TinyInt
  aube_alta        Int?      @db.TinyInt
  pacientes        pacientes @relation(fields: [paciente_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_paciente_cal_get")

  @@index([paciente_id], map: "fk_paciente_cal_get")
}

model diagnostico_nutricional_adulto {
  id                           Int                          @id @default(autoincrement())
  reporte_een_id               Int
  pes                          String?                      @db.VarChar(255)
  intervencion                 String?                      @db.VarChar(50)
  objetivos                    String?                      @db.VarChar(255)
  indicadores                  String?                      @db.VarChar(255)
  criterio                     String?                      @db.VarChar(255)
  progreso                     String?                      @db.VarChar(20)
  reporte_een_adulto_nutricion reporte_een_adulto_nutricion @relation(fields: [reporte_een_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_reporte_diagnostico")

  @@index([reporte_een_id], map: "fk_reporte_diagnostico")
}

model entidades {
  id                 Int                  @id @default(autoincrement())
  nombre             String               @unique(map: "nombre") @db.VarChar(50)
  registro_auditoria registro_auditoria[]
}

model estados {
  id       Int        @id @default(autoincrement())
  codigo   String     @unique(map: "codigo") @db.VarChar(50)
  usuarios usuarios[]
}

model eval_act_fisica_nutricion {
  id                            Int                           @id @default(autoincrement())
  historia_paciente_id          Bytes                         @db.Binary(16)
  fecha                         DateTime?                     @default(dbgenerated("(curdate())")) @db.Date
  tipo                          String?                       @db.VarChar(50)
  porque_no                     String?                       @db.VarChar(255)
  frecuencia                    String?                       @db.VarChar(20)
  duracion                      Int?                          @db.SmallInt
  intensidad                    Int?
  tiempo_de_practica            String?                       @db.VarChar(20)
  pensamientos_con_realizar_AF  String?                       @db.VarChar(50)
  historias_pacientes_nutricion historias_pacientes_nutricion @relation(fields: [historia_paciente_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_eval_act_paciente")

  @@index([historia_paciente_id], map: "fk_eval_act_paciente")
}

model eval_antro_ad_adulto_nutricion {
  id                      Int                       @id @default(autoincrement())
  codo                    Float?                    @db.Float
  frisancho               Float?                    @db.Float
  complexion              String?                   @db.VarChar(20)
  pi_kg                   Float?                    @db.Float
  edema_liq               Float?                    @db.Float
  peso_sin_edema          Float?                    @db.Float
  peso_ajustado           Float?                    @db.Float
  peso_ideal_por          Float?                    @db.Float
  diagnostico_pi          String?                   @db.VarChar(20)
  diagnostico_imc         String?                   @db.VarChar(20)
  pcb                     Float?                    @db.Float
  pcsi                    Float?                    @db.Float
  riesgo_cv               Boolean?
  cadera                  Float?                    @db.Float
  indice_cintura_cadera   Float?                    @db.Float
  diagnostico_icc         String?                   @db.VarChar(20)
  circuf_cuello           Float?                    @db.Float
  riesgo_eo_inf           Boolean?
  eval_antro_ad_nutricion eval_antro_ad_nutricion[]
}

model eval_antro_ad_kid_nutricion {
  id                            Int                       @id @default(autoincrement())
  percentiles_imc               Float?                    @db.Float
  interpretacion_imc            String?                   @db.VarChar(255)
  percentiles_cintura           Float?                    @db.Float
  percentiles_pb                Float?                    @db.Float
  percentiles_pct               Float?                    @db.Float
  percentiles_pcse              Float?                    @db.Float
  peso_para_talla               Float?                    @db.Float
  peso_ideal                    Float?                    @db.Float
  desviacion_estandar_peso      Float?                    @db.Float
  interpretacion_nom_peso       String?                   @db.VarChar(50)
  talla_para_edad               Float?                    @db.Float
  talla_ideal                   Float?                    @db.Float
  desviacion_estandar_talla     Float?                    @db.Float
  interpretacion_nom_talla      String?                   @db.VarChar(50)
  peso_para_edad                Float?                    @db.Float
  desviacion_estandar_peso_edad Float?                    @db.Float
  interpretacion_nom_peso_edad  String?                   @db.VarChar(50)
  diagnostico_general           String?                   @db.VarChar(50)
  resistencia                   Float?                    @db.Float
  reactancia                    Float?                    @db.Float
  angulo_fase                   Float?                    @db.Float
  tan_angulo_fase               Float?                    @db.Float
  eval_antro_ad_nutricion       eval_antro_ad_nutricion[]
}

model eval_antro_ad_nutricion {
  id                             Int                             @id @default(autoincrement())
  paciente_id                    Bytes                           @db.Binary(16)
  eval_antro_ad_kid_id           Int?
  eval_antro_ad_adulto_id        Int?
  fecha                          DateTime?                       @default(dbgenerated("(curdate())")) @db.Date
  peso_actual                    Float?                          @db.Float
  estatura                       Float?                          @db.Float
  imc                            Float?                          @db.Float
  pantorrilla                    Float?                          @db.Float
  cintura                        Float?                          @db.Float
  pb                             Float?                          @db.Float
  pct                            Float?                          @db.Float
  pcse                           Float?                          @db.Float
  eval_antro_ad_adulto_nutricion eval_antro_ad_adulto_nutricion? @relation(fields: [eval_antro_ad_adulto_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_adulto_eval_antro")
  eval_antro_ad_kid_nutricion    eval_antro_ad_kid_nutricion?    @relation(fields: [eval_antro_ad_kid_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_kid_eval_antro")
  pacientes                      pacientes                       @relation(fields: [paciente_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_paciente_eval_antro")

  @@index([eval_antro_ad_adulto_id], map: "fk_adulto_eval_antro")
  @@index([eval_antro_ad_kid_id], map: "fk_kid_eval_antro")
  @@index([paciente_id], map: "fk_paciente_eval_antro")
}

model eval_apetito_nutricion {
  id                        Int            @id @default(autoincrement())
  apetito                   String?        @db.VarChar(20)
  lleno                     String?        @db.VarChar(20)
  sabor_comida              String?        @db.VarChar(20)
  comidas_al_dia            String?        @db.VarChar(20)
  puntaje_total             Int?           @db.TinyInt
  clasif_alteracion_apetito String?        @db.VarChar(20)
  eval_nutr_fh              eval_nutr_fh[]
}

model eval_bioq_nutricion {
  id                           Int                        @id @default(autoincrement())
  paciente_id                  Bytes                      @db.Binary(16)
  fecha                        DateTime?                  @default(dbgenerated("(curdate())")) @db.Date
  id_perfil_anemia             Int?
  id_perfil_endocrino          Int?
  id_perfil_renal_electrolitos Int?
  id_perfil_lipidos            Int?
  id_balance_acido_base        Int?
  id_perfil_orina              Int?
  id_perfil_inflamatorio       Int?
  id_eval_estado_nutr          Int?
  balance_acido_base           balance_acido_base?        @relation(fields: [id_balance_acido_base], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_acido_base_eval_bioq")
  perfil_anemia_nutricion      perfil_anemia_nutricion?   @relation(fields: [id_perfil_anemia], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_anemia_eval_bioq")
  perfil_endocrino             perfil_endocrino?          @relation(fields: [id_perfil_endocrino], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_endocrino_eval_bioq")
  eval_estado_nutricion        eval_estado_nutricion?     @relation(fields: [id_eval_estado_nutr], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_estado_eval_bioq")
  perfil_inflamatorio          perfil_inflamatorio?       @relation(fields: [id_perfil_inflamatorio], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_inflamatorio_eval_bioq")
  perfil_lipidos               perfil_lipidos?            @relation(fields: [id_perfil_lipidos], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_lipidos_eval_bioq")
  perfil_orina                 perfil_orina?              @relation(fields: [id_perfil_orina], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_orina_eval_bioq")
  pacientes                    pacientes                  @relation(fields: [paciente_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_paciente_eval_bioq")
  perfil_renal_electrolitos    perfil_renal_electrolitos? @relation(fields: [id_perfil_renal_electrolitos], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_renal_eval_bioq")

  @@index([id_balance_acido_base], map: "fk_acido_base_eval_bioq")
  @@index([id_perfil_anemia], map: "fk_anemia_eval_bioq")
  @@index([id_perfil_endocrino], map: "fk_endocrino_eval_bioq")
  @@index([id_eval_estado_nutr], map: "fk_estado_eval_bioq")
  @@index([id_perfil_inflamatorio], map: "fk_inflamatorio_eval_bioq")
  @@index([id_perfil_lipidos], map: "fk_lipidos_eval_bioq")
  @@index([id_perfil_orina], map: "fk_orina_eval_bioq")
  @@index([paciente_id], map: "fk_paciente_eval_bioq")
  @@index([id_perfil_renal_electrolitos], map: "fk_renal_eval_bioq")
}

model eval_cal_sueno {
  id                            Int                           @id @default(autoincrement())
  historia_paciente_id          Bytes                         @db.Binary(16)
  fecha                         DateTime?                     @default(dbgenerated("(curdate())")) @db.Date
  horas_sueno                   Int?                          @db.TinyInt
  insomnio                      Int?                          @db.TinyInt
  medicacion                    Int?                          @db.TinyInt
