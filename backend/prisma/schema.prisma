model historias_medicas {
  id                          Bytes                        @id @default(dbgenerated("(uuid_to_bin(uuid()))")) @db.Binary(16)
  paciente_id                 Bytes                        @db.Binary(16)
  usuario_id                  Bytes                        @db.Binary(16)
  creado_at                   DateTime?                    @default(dbgenerated("(curdate())")) @db.Date
  tipo_sangre                 String?                      @db.VarChar(5)
  vacunas_infancia_completas  Boolean?
  motivo_consulta             String?                      @db.Text
  historia_enfermedad_actual  String?                      @db.Text
  antecedentes_familiares     antecedentes_familiares?
  antecedentes_no_patologicos antecedentes_no_patologicos?
  antecedentes_patologicos    antecedentes_patologicos?
  aparatos_sistemas           aparatos_sistemas?
  pacientes                   pacientes                    @relation(fields: [paciente_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_historia_paciente")
  usuarios                    usuarios                     @relation(fields: [usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_historia_usuario")
  informacion_fisica          informacion_fisica?
  inmunizaciones              inmunizaciones?
  notas_evolucion             notas_evolucion[]
  planes_estudio              planes_estudio?
  servicios                   servicios?

  @@index([paciente_id], map: "fk_historia_paciente")
  @@index([usuario_id], map: "fk_historia_usuario")
}

model historias_medicas_nutricion {
  id                            Int                           @id @default(autoincrement())
  historia_paciente_id          Bytes                         @db.Binary(16)
  enfermedad                    String?                       @db.Text
  evol                          Int?
  farmacos                      String?                       @db.Text
  dosis                         String?                       @db.VarChar(20)
  historias_pacientes_nutricion historias_pacientes_nutricion @relation(fields: [historia_paciente_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_historia_medica_historia_paciente")

  @@index([historia_paciente_id], map: "fk_historia_medica_historia_paciente")
}

model historias_pacientes_nutricion {
  id                            Bytes                           @id @default(dbgenerated("(uuid_to_bin(uuid()))")) @db.Binary(16)
  paciente_id                   Bytes                           @db.Binary(16)
  fecha_ingreso                 DateTime?                       @default(dbgenerated("(curdate())")) @db.Date
  motivo_consulta               String?                         @db.Text
  adicciones                    adicciones?
  cal_get_nutr                  cal_get_nutr[]
  eval_act_fisica_nutricion     eval_act_fisica_nutricion[]
  eval_antro_ad_nutricion       eval_antro_ad_nutricion[]
  eval_bioq_nutricion           eval_bioq_nutricion[]
  eval_cal_sueno                eval_cal_sueno[]
  eval_nutr_fh                  eval_nutr_fh[]
  exam_fis_orien_nutricion      exam_fis_orien_nutricion[]
  historias_medicas_nutricion   historias_medicas_nutricion[]
  pacientes                     pacientes                       @relation(fields: [paciente_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_historia_nutricion_paciente")
  patron_alimentacion_nutricion patron_alimentacion_nutricion[]
  rec_24h_nutricion             rec_24h_nutricion[]
  reporte_een_adulto_nutricion  reporte_een_adulto_nutricion[]
  reporte_een_kids_nutricion    reporte_een_kids_nutricion[]
  tpan_nutricion                tpan_nutricion[]
  tratamiento_alt_nutricion     tratamiento_alt_nutricion[]

  @@index([paciente_id], map: "fk_historia_nutricion_paciente")
}

model horarios_comida_nutricion {
  id                       Int          @id @default(autoincrement())
  id_eval_nutr             Bytes        @unique(map: "id_eval_nutr") @db.Binary(16)
  hora_desayuno            String?      @db.VarChar(20)
  hora_comida              String?      @db.VarChar(20)
  hora_cena                String?      @db.VarChar(20)
  hora_colac_1             String?      @db.VarChar(20)
  hora_colac_2             String?      @db.VarChar(20)
  hora_colac_3             String?      @db.VarChar(20)
  hora_despierto           String?      @db.VarChar(20)
  tipo_alimentacion        String?      @db.VarChar(10)
  problemas_masticar       Boolean?
  problemas_pasar_alimento Boolean?
  perdida_dientes          Boolean?
  pensamientos_sobre_dieta String?      @db.Text
  eval_nutr_fh             eval_nutr_fh @relation(fields: [id_eval_nutr], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_horarios_eval_nutr")
}

model informacion_fisica {
  id                 Int                @id @default(autoincrement())
  historia_medica_id Bytes?             @unique(map: "historia_medica_id") @db.Binary(16)
  nota_evolucion_id  Bytes?             @unique(map: "nota_evolucion_id") @db.Binary(16)
  peso               Float?             @db.Float
  altura             Float?             @db.Float
  pa_sistolica       Int?
  pa_diastolica      Int?
  fc                 Int?
  fr                 Int?
  circ_cintura       Float?             @db.Float
  circ_cadera        Float?             @db.Float
  sp_o2              Float?             @db.Float
  glucosa_capilar    Float?             @db.Float
  temperatura        Float?             @db.Float
  exploracion_fisica String?            @db.Text
  habito_exterior    String?            @db.Text
  historias_medicas  historias_medicas? @relation(fields: [historia_medica_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_infoF_historia")
  notas_evolucion    notas_evolucion?   @relation(fields: [nota_evolucion_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_infoF_nota")
}

model inmunizaciones {
  id                 Int               @id @default(autoincrement())
  historia_medica_id Bytes             @unique(map: "historia_medica_id") @db.Binary(16)
  influenza          DateTime?         @db.Timestamp(0)
  tetanos            DateTime?         @db.Timestamp(0)
  hepatitis_b        DateTime?         @db.Timestamp(0)
  covid_19           DateTime?         @db.Timestamp(0)
  otros              String?           @db.Text
  historias_medicas  historias_medicas @relation(fields: [historia_medica_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_inmu_historia")
}

model notas_evolucion {
  id                                  Bytes               @id @default(dbgenerated("(uuid_to_bin(uuid()))")) @db.Binary(16)
  historia_medica_id                  Bytes               @db.Binary(16)
  usuario_id                          Bytes               @db.Binary(16)
  motivo_consulta                     String?             @db.Text
  ant_gine_andro                      String?             @db.Text
  estudios_complementarios_efectuados String?             @db.Text
  creado_at                           DateTime?           @default(now()) @db.DateTime(0)
  aparatos_sistemas                   aparatos_sistemas?
  informacion_fisica                  informacion_fisica?
  historias_medicas                   historias_medicas   @relation(fields: [historia_medica_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_nota_historia")
  usuarios                            usuarios            @relation(fields: [usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_nota_usuario")
  planes_estudio                      planes_estudio?

  @@index([historia_medica_id], map: "fk_nota_historia")
  @@index([usuario_id], map: "fk_nota_usuario")
}

model pacientes {
  id                            Bytes                           @id @default(dbgenerated("(uuid_to_bin(uuid()))")) @db.Binary(16)
  doctor_id                     Bytes                           @db.Binary(16)
  nombre                        String?                         @db.VarChar(255)
  apellidos                     String?                         @db.VarChar(255)
  fecha_nacimiento              DateTime?                       @db.Date
  es_externo                    Boolean?                        @default(false)
  correo                        String?                         @db.VarChar(255)
  telefono                      String?                         @db.VarChar(30)
  genero                        String?                         @db.VarChar(20)
  domicilio                     String?                         @db.VarChar(255)
  fuente_informacion            String?                         @db.VarChar(100)
  lugar_nacimiento              String?                         @db.VarChar(255)
  ocupacion                     String?                         @db.VarChar(100)
  estado_civil                  String?                         @db.VarChar(50)
