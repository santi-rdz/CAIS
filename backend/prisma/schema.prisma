generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model acciones {
  id                 Int                  @id @default(autoincrement())
  codigo             String               @unique(map: "codigo") @db.VarChar(50)
  registro_auditoria registro_auditoria[]
}

model adicciones {
  id                            Int                           @id @default(autoincrement())
  historia_paciente_id          Bytes                         @unique(map: "historia_paciente_id") @db.Binary(16)
  adicto_tabaco                 String?                       @db.VarChar(10)
  tabaco_frecuencia             String?                       @db.VarChar(20)
  num_cigarros_d                Int?                          @db.TinyInt
  adicto_alcohol                String?                       @db.VarChar(10)
  alcohol_frecuencia            String?                       @db.VarChar(20)
  ml_ocasion                    Int?                          @db.SmallInt
  adicto_droga                  String?                       @db.VarChar(10)
  drogas_frecuencia             String?                       @db.VarChar(20)
  cual_droga                    String?                       @db.Text
  adicto_med_contr              String?                       @db.VarChar(10)
  med_contr_frecuencia          String?                       @db.VarChar(20)
  cual_med_contr                String?                       @db.Text
  historias_pacientes_nutricion historias_pacientes_nutricion @relation(fields: [historia_paciente_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_adicciones_historia_paciente")
}

model antecedentes_familiares {
  id                 Int               @id @default(autoincrement())
  historia_medica_id Bytes             @unique(map: "historia_medica_id") @db.Binary(16)
  padre              String?           @db.VarChar(255)
  madre              String?           @db.VarChar(255)
  abuelo_paterno     String?           @db.VarChar(255)
  abuelo_materno     String?           @db.VarChar(255)
  abuela_paterna     String?           @db.VarChar(255)
  abuela_materna     String?           @db.VarChar(255)
  otros              String?           @db.VarChar(255)
  historias_medicas  historias_medicas @relation(fields: [historia_medica_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_af_historia")
}

model antecedentes_no_patologicos {
  id                            Int               @id @default(autoincrement())
  historia_medica_id            Bytes             @unique(map: "historia_medica_id") @db.Binary(16)
  alimentacion_adecuada         Boolean?
  calidad_cantidad_alimentacion String?           @db.Text
  higiene_adecuada              String?           @db.Text
  actividad_fisica              String?           @db.Text
  inmunizaciones_completas      Boolean?
  zoonosis                      Boolean?
  tipo_zoonosis                 String?           @db.Text
  historias_medicas             historias_medicas @relation(fields: [historia_medica_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_antecedentes_np_historia")
}

model antecedentes_patologicos {
  id                      Int               @id @default(autoincrement())
  historia_medica_id      Bytes             @unique(map: "historia_medica_id") @db.Binary(16)
  cronico_degenerativos   String?           @db.Text
  quirurgicos             String?           @db.Text
  hospitalizaciones       String?           @db.Text
  traumaticos             String?           @db.Text
  transfusionales         String?           @db.Text
  transplantes            String?           @db.Text
  alergicos               String?           @db.Text
  infectocontagiosos      String?           @db.Text
  toxicomanias            String?           @db.Text
  covid_19                String?           @db.Text
  psicologia_psiquiatria  String?           @db.Text
  gyo                     String?           @db.Text
  enfermedades_congenitas String?           @db.Text
  enfermedades_infancia   String?           @db.Text
  historias_medicas       historias_medicas @relation(fields: [historia_medica_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_ap_historia")
}

model aparatos_sistemas {
  id                 Int                @id @default(autoincrement())
  historia_medica_id Bytes?             @unique(map: "historia_medica_id") @db.Binary(16)
  nota_evolucion_id  Bytes?             @unique(map: "nota_evolucion_id") @db.Binary(16)
  neurologico        String?            @db.Text
  cardiovascular     String?            @db.Text
  respiratorio       String?            @db.Text
  hematologico       String?            @db.Text
  digestivo          String?            @db.Text
  musculoesqueletico String?            @db.Text
  genitourinario     String?            @db.Text
  endocrinologico    String?            @db.Text
  metabolico         String?            @db.Text
  nutricional        String?            @db.Text
  historias_medicas  historias_medicas? @relation(fields: [historia_medica_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_as_historia")
  notas_evolucion    notas_evolucion?   @relation(fields: [nota_evolucion_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_as_nota")
}

model areas {
  id       Int        @id @default(autoincrement())
  nombre   String     @unique(map: "nombre") @db.VarChar(100)
  usuarios usuarios[]
}

model entidades {
  id                 Int                  @id @default(autoincrement())
  nombre             String               @unique(map: "nombre") @db.VarChar(50)
  registro_auditoria registro_auditoria[]
}

model estados {
  id       Int        @id @default(autoincrement())
  codigo   String     @unique(map: "codigo") @db.VarChar(50)
  usuarios usuarios[]
}

model eval_act_fisica_nutricion {
  id                            Bytes                         @id @default(dbgenerated("(uuid_to_bin(uuid()))")) @db.Binary(16)
  historia_paciente_id          Bytes                         @db.Binary(16)
  fecha                         DateTime?                     @default(dbgenerated("(curdate())")) @db.Date
  tipo                          String?                       @db.VarChar(50)
  porque_no                     String?                       @db.Text
  frecuencia                    String?                       @db.VarChar(20)
  duracion                      Int?                          @db.SmallInt
  intensidad                    Int?
  clasif_tiempo_af              String?                       @db.VarChar(20)
  tiempo_de_practica            String?                       @db.VarChar(20)
  pensamientos_con_realizar_AF  String?                       @db.VarChar(50)
  historias_pacientes_nutricion historias_pacientes_nutricion @relation(fields: [historia_paciente_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_eval_act_paciente")

  @@index([historia_paciente_id], map: "fk_eval_act_paciente")
}

model eval_antro_ad_adulto_nutricion {
  id                      Int                     @id @default(autoincrement())
  eval_antro_id           Bytes                   @unique(map: "eval_antro_id") @db.Binary(16)
  codo                    Float?                  @db.Float
  frisancho               Float?                  @db.Float
  complexion              String?                 @db.VarChar(20)
  pi_kg                   Float?                  @db.Float
  edema_liq               Float?                  @db.Float
  peso_sin_edema          Float?                  @db.Float
  peso_ajustado           Float?                  @db.Float
  peso_ideal_por          Float?                  @db.Float
  diagnostico_pi          String?                 @db.VarChar(20)
  diagnostico_imc         String?                 @db.VarChar(20)
  pcb                     Float?                  @db.Float
  pcsi                    Float?                  @db.Float
  riesgo_cv               Boolean?
  cadera                  Float?                  @db.Float
  indice_cintura_cadera   Float?                  @db.Float
  diagnostico_icc         String?                 @db.VarChar(20)
  circuf_cuello           Float?                  @db.Float
  riesgo_eo_inf           Boolean?
  eval_antro_ad_nutricion eval_antro_ad_nutricion @relation(fields: [eval_antro_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_eval_antro_ad_adulto")
}

model eval_antro_ad_kid_nutricion {
  id                            Int                     @id @default(autoincrement())
  eval_antro_id                 Bytes                   @unique(map: "eval_antro_id") @db.Binary(16)
  percentiles_imc               Float?                  @db.Float
  interpretacion_imc            String?                 @db.VarChar(255)
  percentiles_cintura           Float?                  @db.Float
  percentiles_pb                Float?                  @db.Float
  percentiles_pct               Float?                  @db.Float
  percentiles_pcse              Float?                  @db.Float
  peso_para_talla               Float?                  @db.Float
  peso_ideal                    Float?                  @db.Float
  desviacion_estandar_peso      Float?                  @db.Float
  interpretacion_nom_peso       String?                 @db.VarChar(50)
  talla_para_edad               Float?                  @db.Float
  talla_ideal                   Float?                  @db.Float
  desviacion_estandar_talla     Float?                  @db.Float
  interpretacion_nom_talla      String?                 @db.VarChar(50)
  peso_para_edad                Float?                  @db.Float
  desviacion_estandar_peso_edad Float?                  @db.Float
  interpretacion_nom_peso_edad  String?                 @db.VarChar(50)
  diagnostico_general           String?                 @db.VarChar(50)
  resistencia                   Float?                  @db.Float
  reactancia                    Float?                  @db.Float
  angulo_fase                   Float?                  @db.Float
  tan_angulo_fase               Float?                  @db.Float
  eval_antro_ad_nutricion       eval_antro_ad_nutricion @relation(fields: [eval_antro_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_eval_antro_ad_kid")
}

model eval_apetito_nutricion {
  id                        Int          @id @default(autoincrement())
  id_eval_nutr              Bytes        @unique(map: "id_eval_nutr") @db.Binary(16)
  apetito                   String?      @db.VarChar(20)
  lleno                     String?      @db.VarChar(20)
  sabor_comida              String?      @db.VarChar(20)
  comidas_al_dia            String?      @db.VarChar(20)
  puntaje_total             Int?         @db.TinyInt
  clasif_alteracion_apetito String?      @db.VarChar(20)
  eval_nutr_fh              eval_nutr_fh @relation(fields: [id_eval_nutr], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_apetito_eval_nutr")
}

model eval_cal_sueno {
  id                            Bytes                         @id @default(dbgenerated("(uuid_to_bin(uuid()))")) @db.Binary(16)
  historia_paciente_id          Bytes                         @db.Binary(16)
  fecha                         DateTime?                     @default(dbgenerated("(curdate())")) @db.Date
  horas_sueno                   Int?                          @db.TinyInt
  clasif_horas_sueno            String?                       @db.VarChar(20)
  insomnio                      String?                       @db.VarChar(10)
  medicacion                    String?                       @db.VarChar(10)
  historias_pacientes_nutricion historias_pacientes_nutricion @relation(fields: [historia_paciente_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_cal_sueno_paciente")

  @@index([historia_paciente_id], map: "fk_cal_sueno_paciente")
}

model eval_perdida_peso_nutricion {
  id                       Int                      @id @default(autoincrement())
  exam_fis_id              Bytes                    @unique(map: "exam_fis_id") @db.Binary(16)
  peso_habitual            Float?                   @db.Float
  peso_perdido             Float?                   @db.Float
  porcentaje_peso_perdido  Float?                   @db.Float
  exam_fis_orien_nutricion exam_fis_orien_nutricion @relation(fields: [exam_fis_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_perdida_peso_exam_fis")
}

model eval_semiologia_nutricional {
  id                               Int                      @id @default(autoincrement())
  exam_fis_id                      Bytes                    @unique(map: "exam_fis_id") @db.Binary(16)
  pcb                              String?                  @db.VarChar(10)
  pct                              String?                  @db.VarChar(10)
  fondo_ojo                        String?                  @db.VarChar(10)
  diag_reservagrasa                String?                  @db.VarChar(10)
  sienes                           String?                  @db.VarChar(10)
  clavicula                        String?                  @db.VarChar(10)
  hombros                          String?                  @db.VarChar(10)
  omoplato                         String?                  @db.VarChar(10)
  interoseos_mano                  String?                  @db.VarChar(10)
  costillas                        String?                  @db.VarChar(10)
  espalda_alta                     String?                  @db.VarChar(10)
  cuadriceps                       String?                  @db.VarChar(10)
  pantorrilla                      String?                  @db.VarChar(10)
  diag_reserva_muscular            String?                  @db.VarChar(15)
  edema                            String?                  @db.VarChar(20)
  descripcion                      String?                  @db.Text
  descripcion_sist_genito_urinario String?                  @db.Text
  exam_fis_orien_nutricion         exam_fis_orien_nutricion @relation(fields: [exam_fis_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_semiologia_exam_fis")
}

model frec_consumo_alimentos_nutricion {
