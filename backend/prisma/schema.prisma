  carne_roja                 String?      @db.VarChar(20)
  quesos                     String?      @db.VarChar(20)
  huevo_entero               String?      @db.VarChar(20)
  clara_huevo                String?      @db.VarChar(20)
  embutidos                  String?      @db.VarChar(20)
  leguminosas                String?      @db.VarChar(20)
  tortilla_maiz              String?      @db.VarChar(20)
  cant_tortilla_maiz         String?      @db.VarChar(20)
  tortilla_harina            String?      @db.VarChar(20)
  cant_tortilla_harina       String?      @db.VarChar(20)
  pan_de_caja                String?      @db.VarChar(20)
  galletas_industr           String?      @db.VarChar(20)
  pan_dulce                  String?      @db.VarChar(20)
  cereal_de_caja             String?      @db.VarChar(20)
  frituras_papas             String?      @db.VarChar(20)
  birote_bolillo             String?      @db.VarChar(20)
  pastas_arroz               String?      @db.VarChar(20)
  aderezos_capsu             String?      @db.VarChar(20)
