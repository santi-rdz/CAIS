  usuarios    usuarios   @relation(fields: [usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_audit_usuario")

  @@index([accion_id], map: "fk_audit_accion")
  @@index([entidad_id], map: "fk_audit_entidad")
  @@index([usuario_id], map: "fk_audit_usuario")
  @@index([objetivo_id], map: "idx_audit_objetivo")
  @@index([paciente_id], map: "idx_audit_paciente")
}

