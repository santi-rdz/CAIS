  @@index([historia_paciente_id], map: "fk_cal_sueno_paciente")
}

model eval_estado_nutricion {
  id                  Int                   @id @default(autoincrement())
  leucocitos          Float?                @db.Float
  linfocitos          Float?                @db.Float
  ctl                 Float?                @db.Float
  albumina            Float?                @db.Float
  pre_albumina        Float?                @db.Float
  transferrina        Float?                @db.Float
  eval_bioq_nutricion eval_bioq_nutricion[]
}

model eval_nutr_fh {
  id                               Int                               @id @default(autoincrement())
  paciente_id                      Bytes                             @db.Binary(16)
  fecha                            DateTime?                         @default(dbgenerated("(curdate())")) @db.Date
  id_horarios_comida               Int?
  id_eval_apetito                  Int?
  id_frec_consumo                  Int?
  eval_apetito_nutricion           eval_apetito_nutricion?           @relation(fields: [id_eval_apetito], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_apetito_eval_nutr")
  frec_consumo_alimentos_nutricion frec_consumo_alimentos_nutricion? @relation(fields: [id_frec_consumo], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_frec_consumo_eval_nutr")
  horarios_comida_nutricion        horarios_comida_nutricion?        @relation(fields: [id_horarios_comida], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_horarios_eval_nutr")
  pacientes                        pacientes                         @relation(fields: [paciente_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_paciente_eval_nutr")

  @@index([id_eval_apetito], map: "fk_apetito_eval_nutr")
  @@index([id_frec_consumo], map: "fk_frec_consumo_eval_nutr")
  @@index([id_horarios_comida], map: "fk_horarios_eval_nutr")
  @@index([paciente_id], map: "fk_paciente_eval_nutr")
}

