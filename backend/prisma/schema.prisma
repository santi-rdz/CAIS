model eval_sintomas_gastroin_nutricion {
  id                       Int                      @id @default(autoincrement())
  exam_fis_id              Int
  presenta_sgi             Boolean?
  presencia                String?                  @db.VarChar(50)
  exam_fis_orien_nutricion exam_fis_orien_nutricion @relation(fields: [exam_fis_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_exam_fis_sintomas")

  @@index([exam_fis_id], map: "fk_exam_fis_sintomas")
}

model exam_fis_orien_nutricion {
  id                               Int                                @id @default(autoincrement())
  paciente_id                      Bytes                              @db.Binary(16)
  fecha                            DateTime?                          @default(dbgenerated("(curdate())")) @db.Date
  id_perdida_peso                  Int
  id_signos_vitales                Int
  id_semiologia                    Int
  eval_sintomas_gastroin_nutricion eval_sintomas_gastroin_nutricion[]
  pacientes                        pacientes                          @relation(fields: [paciente_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_paciente_exam_fis")
  eval_perdida_peso_nutricion      eval_perdida_peso_nutricion        @relation(fields: [id_perdida_peso], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_perdida_peso_exam_fis")
  eval_semiologia_nutricional      eval_semiologia_nutricional        @relation(fields: [id_semiologia], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_semiologia_exam_fis")
  signos_vitales_nutricion         signos_vitales_nutricion           @relation(fields: [id_signos_vitales], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_signos_vitales_exam_fis")

  @@index([paciente_id], map: "fk_paciente_exam_fis")
  @@index([id_perdida_peso], map: "fk_perdida_peso_exam_fis")
  @@index([id_semiologia], map: "fk_semiologia_exam_fis")
  @@index([id_signos_vitales], map: "fk_signos_vitales_exam_fis")
}

