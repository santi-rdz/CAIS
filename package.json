{
  "name": "cais",
  "version": "0.0.1",
  "description": "Administration System for UABC \"Centro de Atencion Integral para la Salud\"",
  "homepage": "https://github.com/santi-rdz/CAIS#readme",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "bugs": {
    "url": "https://github.com/santi-rdz/CAIS/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santi-rdz/CAIS.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "dc:build": "docker compose build",
    "dc:up": "docker compose up -d",
    "dc:rebuild": "docker compose up -d --build",
    "dc:down": "docker compose down",
    "dc:down:v": "docker compose down -v",
    "dc:restart": "docker compose restart",
    "dc:logs": "docker compose logs -f",
    "dc:ps": "docker compose ps",
    "dc:exec:fe": "docker compose exec frontend sh",
    "dc:exec:be": "docker compose exec backend sh",
    "dc:sql": "docker compose exec db mysql -u user -p"
  },
  "dependencies": {
    "frontend": "^0.0.0"
  },
  "devDependencies": {
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "0.4.22",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2"
  }
}
