{
  "name": "cais",
  "version": "0.0.1",
  "description": "Administration System for UABC \"Centro de Atencion Integral para la Salud\"",
  "homepage": "https://github.com/santi-rdz/CAIS#readme",
  "packageManager": "pnpm@11.5.1",
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "bugs": {
    "url": "https://github.com/santi-rdz/CAIS/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santi-rdz/CAIS.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": "11.5.1"
  },
  "main": "index.js",
  "scripts": {
    "//— Lint —": "",
    "check": "eslint . && prettier . --check",
    "format": "prettier . --write",
    "//— Setup (primera vez) —": "",
    "setup": "pnpm install && pnpm db:up && pnpm db:wait && pnpm --filter backend exec prisma generate && pnpm seed",
    "//— Desarrollo (host nativo + DB en Docker) —": "",
    "dev": "pnpm db:up && pnpm --parallel --filter frontend --filter backend run dev",
    "seed": "pnpm --filter backend exec node prisma/seed.js",
    "//— DB de desarrollo —": "",
    "db:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "db:fresh": "docker compose -f docker-compose.dev.yml down -v && pnpm db:up && pnpm db:wait && pnpm seed",
    "db:logs": "docker compose -f docker-compose.dev.yml logs -f db",
    "db:sql": "docker compose -f docker-compose.dev.yml exec db mysql -u user -puser cais",
    "db:wait": "node scripts/db-wait.mjs",
    "//— Producción (Docker completo) —": "",
    "build": "docker compose build",
    "up": "docker compose up -d",
    "down": "docker compose down",
    "restart": "docker compose up -d --build",
    "fresh": "docker compose down -v && docker compose up -d --build --wait",
    "logs": "docker compose logs -f",
    "ps": "docker compose ps",
    "//— Tests —": "",
    "test": "pnpm --filter backend test",
    "test:debug": "pnpm --filter backend test:debug",
    "preinstall": "node scripts/ensure-pnpm.js",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css,html}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.26",
    "eslint-plugin-unused-imports": "4.4.1",
    "globals": "14.0.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2"
  }
}
