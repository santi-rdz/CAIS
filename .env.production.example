IMAGE_TAG=v0.0.1
# BUILD_PLATFORM=linux/amd64   # ARM → linux/arm64

# App
DATABASE_URL=mysql://user:CAMBIA_ESTO@db:3306/cais
FRONTEND_URL=http://localhost:8080
VITE_API_URL=/api               # nginx proxea /api → backend, no tocar
SESSION_SECRET=CAMBIA_ESTO      # openssl rand -hex 32
# SESSION_COOKIE_SECURE=false   # solo para pruebas HTTP

# Puertos publicados
FRONTEND_PORT=8080
BACKEND_PORT=8001               # quitar cuando el proxy esté validado

# MySQL
MYSQL_ROOT_PASSWORD=CAMBIA_ESTO_root
MYSQL_DATABASE=cais
MYSQL_USER=user
MYSQL_PASSWORD=CAMBIA_ESTO

# SMTP
EMAIL_USER=
EMAIL_PASS=
