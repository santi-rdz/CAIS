# ──────────────────────────────────────────────────────────
# CAIS — plantilla de variables de PRODUCCIÓN
# Uso:
#   cp .env.production.example .env.production
#   # edita valores
#   docker compose --env-file .env.production up -d --build
# ──────────────────────────────────────────────────────────

# ─── Versión de la imagen (requerido) ─────────────────────
# En CI lo seteas con $GIT_SHA o un tag semver.
IMAGE_TAG=v0.0.1

# ─── Plataforma del build (opcional) ──────────────────────
# Si construyes en M1/M2 Mac y deployas a x86, déjalo en linux/amd64.
# Si tu server es ARM (Graviton), cambia a linux/arm64.
# BUILD_PLATFORM=linux/amd64

# ─── App ──────────────────────────────────────────────────
# La DB se resuelve por hostname `db` dentro de la red docker.
DATABASE_URL=mysql://user:CAMBIA_ESTO@db:3306/cais

# URL pública del frontend (para CORS + correos transaccionales).
FRONTEND_URL=http://localhost:8080

# El frontend pega a /api → nginx lo proxea al backend. No tocar.
VITE_API_URL=/api

# Secret de sesión. Genera con: openssl rand -hex 32
SESSION_SECRET=CAMBIA_ESTO_openssl_rand_hex_32

# Cookie de sesión con flag Secure (solo HTTPS).
# Default = true en prod. Pon false SOLO para pruebas locales sobre HTTP.
# SESSION_COOKIE_SECURE=false

# ─── Puertos publicados ───────────────────────────────────
FRONTEND_PORT=8080
# Solo necesario mientras el backend no esté 100% detrás del proxy.
# Cuando confirmes que /api funciona, quita la línea `ports:` del
# backend en docker-compose.yml y deja la app blindada.
BACKEND_PORT=8001

# ─── MySQL ────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=CAMBIA_ESTO_root
MYSQL_DATABASE=cais
MYSQL_USER=user
MYSQL_PASSWORD=CAMBIA_ESTO

# ─── SMTP (Gmail con app password) ────────────────────────
EMAIL_USER=
EMAIL_PASS=
